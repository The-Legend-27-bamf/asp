<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Akademska Evidencija</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Asp_projekt.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="app-nav app-shell">
            <a class="app-brand" asp-area="" asp-controller="Home" asp-action="Index">Akademska Evidencija</a>
            <div class="app-links">
                <a asp-area="" asp-controller="Student" asp-action="Index">Studenti</a>
                <a asp-area="" asp-controller="Profesor" asp-action="Index">Profesori</a>
                <a asp-area="" asp-controller="Kolegij" asp-action="Index">Kolegiji</a>
                <a asp-area="" asp-controller="Fakultet" asp-action="Index">Fakulteti</a>
                <a asp-area="" asp-controller="Ocjena" asp-action="Index">Ocjene</a>
                <a asp-area="" asp-controller="Izvjestaj" asp-action="Index">Izvjestaji</a>
            </div>
        </nav>
    </header>

    <div class="app-shell">
        <main role="main" class="main-content">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="app-shell">
            &copy; 2026 Akademska Evidencija
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
