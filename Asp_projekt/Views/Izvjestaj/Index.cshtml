@model IEnumerable<Izvjestaj>
@{
    ViewData["Title"] = "Izvjestaji";
}

<section class="page-head">
    <h1 class="page-title">Izvjestaji</h1>
    <p class="page-subtitle">Automatski generirani izvjestaji po profesorima.</p>
</section>

<section class="list-toolbar">
    <p class="empty-note">Izvjestaji su read-only: generiraju se iz postojecih podataka i ne unose se rucno.</p>
</section>

<section class="list-toolbar"
         data-ajax-list-root
         data-search-url="@Url.Action("Search", "Izvjestaj")"
         data-target-id="izvjestajListTarget">
    <label class="info-label" for="izvjestajSearch">Brza pretraga</label>
    <input id="izvjestajSearch"
           type="search"
           class="search-input"
           placeholder="Pretrazi po profesoru ili katedri..."
           data-ajax-search-input />
</section>

<div id="izvjestajListTarget">
    <partial name="_IzvjestajCards" model="Model" />
</div>
