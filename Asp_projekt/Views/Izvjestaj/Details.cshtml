@model Izvjestaj
@{
    ViewData["Title"] = "Detalji izvjestaja";
}

<section class="detail-hero">
    <span class="hero-badge">Izvjestaj</span>
    <div class="hero-main">
        <h1 class="hero-title">Izvjestaj @Model.DatumGeneriranja.ToString("dd.MM.yyyy")</h1>
        <p class="hero-subtitle">Detaljni prikaz podataka o izvjestaju.</p>
    </div>
    <div class="hero-pills">
        <span class="hero-pill">Prosjek <strong>@Model.ProsjecnaOcjena.ToString("0.00")</strong></span>
        <span class="hero-pill">Ocjene <strong>@Model.BrojOcjena</strong></span>
        <span class="hero-pill">Datum <strong>@Model.DatumGeneriranja.ToString("dd.MM.yyyy")</strong></span>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card core-card">
        <header class="card-header">
            <h2>Osnovni podaci</h2>
            <span class="card-tag">Pregled</span>
        </header>
        <div class="info-grid">
            <div class="info-item"><span class="info-label">Prosjecna ocjena</span><span class="info-value">@Model.ProsjecnaOcjena.ToString("0.00")</span></div>
            <div class="info-item"><span class="info-label">Broj ocjena</span><span class="info-value">@Model.BrojOcjena</span></div>
            <div class="info-item"><span class="info-label">Datum generiranja</span><span class="info-value">@Model.DatumGeneriranja.ToString("dd.MM.yyyy HH:mm")</span></div>
        </div>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Profesor</h2>
            <span class="card-tag">Povezano</span>
        </header>
        <div class="info-grid">
            <div class="info-item"><span class="info-label">Ime i prezime</span><span class="info-value">@Model.Profesor.Ime @Model.Profesor.Prezime</span></div>
            <div class="info-item"><span class="info-label">Katedra</span><span class="info-value">@Model.Profesor.Katedra</span></div>
        </div>
        <div class="inline-links inline-links--spaced">
            <a class="link-btn link-btn--ghost" asp-controller="Profesor" asp-action="Details" asp-route-id="@Model.Profesor.Id">Detalji profesora</a>
        </div>
    </article>
</section>

<section class="list-toolbar">
    <p class="empty-note">Read-only: ovaj izvjestaj je izveden iz postojecih ocjena i profesora, zato nema Create/Edit/Delete akcija.</p>
</section>

<a class="link-btn link-btn--ghost back-link" asp-action="Index">Povratak na Index</a>
