@model Ocjena
@{
    ViewData["Title"] = "Detalji ocjene";
}

<section class="detail-hero">
    <span class="hero-badge">Ocjena</span>
    <div class="hero-main">
        <h1 class="hero-title">Ocjena (@Model.Tip)</h1>
        <p class="hero-subtitle">Detaljni prikaz podataka o ocjeni.</p>
    </div>
    <div class="hero-pills">
        @{
            var filledStars = Model.Vrijednost;
            if (filledStars < 0) filledStars = 0;
            if (filledStars > 5) filledStars = 5;
        }
        <span class="chip chip--sun chip--stars" aria-label="Ocjena: @Model.Vrijednost od 5">
            <span class="stars" aria-hidden="true">
                @for (var i = 1; i <= 5; i++)
                {
                    <svg class="star @(i <= filledStars ? "is-filled" : "is-empty")" viewBox="0 0 24 24" focusable="false" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2.7l2.9 6.1 6.7.9-4.9 4.7 1.2 6.7L12 17.9 6.1 21.1l1.2-6.7-4.9-4.7 6.7-.9L12 2.7Z" />
                    </svg>
                }
            </span>
        </span>
        <span class="hero-pill">Datum <strong>@Model.DatumOcjene.ToString("dd.MM.yyyy")</strong></span>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card core-card">
        <header class="card-header">
            <h2>Osnovni podaci</h2>
            <span class="card-tag">Ocjena</span>
        </header>
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Vrijednost</span>
                <span class="info-value">
                    <span class="stars" aria-hidden="true">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <svg class="star @(i <= filledStars ? "is-filled" : "is-empty")" viewBox="0 0 24 24" focusable="false" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 2.7l2.9 6.1 6.7.9-4.9 4.7 1.2 6.7L12 17.9 6.1 21.1l1.2-6.7-4.9-4.7 6.7-.9L12 2.7Z" />
                            </svg>
                        }
                    </span>
                </span>
            </div>
            <div class="info-item"><span class="info-label">Tip</span><span class="info-value">@Model.Tip</span></div>
            <div class="info-item"><span class="info-label">Komentar</span><span class="info-value">@Model.Komentar</span></div>
            <div class="info-item"><span class="info-label">Datum</span><span class="info-value">@Model.DatumOcjene.ToString("dd.MM.yyyy")</span></div>
        </div>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Povezani entiteti</h2>
            <span class="card-tag">Veze</span>
        </header>
        <div class="chip-list">
            <a class="name-chip" asp-controller="Profesor" asp-action="Details" asp-route-id="@Model.Profesor.Id">Profesor: @Model.Profesor.Ime @Model.Profesor.Prezime</a>
            <a class="name-chip" asp-controller="Student" asp-action="Details" asp-route-id="@Model.Student.Id">Student: @Model.Student.Ime @Model.Student.Prezime</a>
            <a class="name-chip" asp-controller="Kolegij" asp-action="Details" asp-route-id="@Model.Kolegij.Id">Kolegij: @Model.Kolegij.Naziv</a>
        </div>
    </article>
</section>

<a class="link-btn link-btn--ghost back-link" asp-action="Index">Povratak na Index</a>
