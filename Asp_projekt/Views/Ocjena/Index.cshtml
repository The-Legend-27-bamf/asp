@model IEnumerable<Ocjena>
@{
    ViewData["Title"] = "Ocjene";
}

<section class="page-head">
    <h1 class="page-title">Ocjene</h1>
    <p class="page-subtitle">Sve ocjene s osnovnim informacijama i detaljima.</p>
</section>

<section class="page-actions">
    <a class="link-btn" asp-action="Create">Daj ocjenu</a>
</section>

<section class="list-toolbar"
         data-ajax-list-root
         data-search-url="@Url.Action("Search", "Ocjena")"
         data-target-id="ocjenaListTarget">
    <label class="info-label" for="ocjenaSearch">Brza pretraga</label>
    <input id="ocjenaSearch"
           type="search"
           class="search-input"
           placeholder="Pretrazi po studentu, kolegiju ili komentaru..."
           data-ajax-search-input />
</section>

<div id="ocjenaListTarget">
    <partial name="_OcjenaCards" model="Model" />
</div>
