@model IEnumerable<Ocjena>
@{
    ViewData["Title"] = "Ocjene";
    var ocjene = new List<Ocjena>(Model);
}

<section class="page-head">
    <h1 class="page-title">Ocjene</h1>
    <p class="page-subtitle">Sve ocjene s osnovnim informacijama i detaljima.</p>
</section>

@if (ocjene.Count == 0)
{
    <p class="empty-note">Nema dostupnih ocjena.</p>
}
else
{
    <section class="cards-grid">
        @foreach (var ocjena in ocjene)
        {
            <article class="entity-card">
                <div class="card-top">
                    <h2 class="card-title">Ocjena @ocjena.Vrijednost (@ocjena.Tip)</h2>
                    <span class="chip chip--id">ID @ocjena.Id</span>
                </div>
                <div class="card-lines">
                    <p class="card-meta">Student: @ocjena.Student.Ime @ocjena.Student.Prezime</p>
                    <p class="card-meta">Kolegij: @ocjena.Kolegij.Naziv</p>
                    <p class="card-meta">Datum: @ocjena.DatumOcjene.ToString("dd.MM.yyyy")</p>
                </div>
                <a class="link-btn" asp-action="Details" asp-route-id="@ocjena.Id">Details</a>
            </article>
        }
    </section>
}
