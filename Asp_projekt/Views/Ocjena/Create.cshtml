@model Asp_projekt.Models.OcjenaCreateViewModel
@using Asp_projekt.Models
@{
    ViewData["Title"] = "Daj ocjenu";
}

<section class="detail-hero">
    <span class="hero-badge">Ocjena</span>
    <div class="hero-main">
        <h1 class="hero-title">Daj ocjenu</h1>
        <p class="hero-subtitle">Unesi novu ocjenu za odabranog profesora, studenta i kolegij.</p>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card core-card">
        <header class="card-header">
            <h2>Podaci</h2>
            <span class="card-tag">Create</span>
        </header>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly"></div>

            <div class="info-grid">
                <div class="info-item">
                    <label class="info-label" asp-for="ProfesorId">Profesor</label>
                    <select asp-for="ProfesorId">
                        @foreach (var profesor in Model.Profesori)
                        {
                            if (Model.ProfesorId == profesor.Id)
                            {
                                <option value="@profesor.Id" selected
                                        data-naziv="@profesor.Naziv"
                                        data-katedra="@profesor.Katedra"
                                        data-fakultet="@(profesor.FakultetNaziv ?? string.Empty)">@profesor.Naziv</option>
                            }
                            else
                            {
                                <option value="@profesor.Id"
                                        data-naziv="@profesor.Naziv"
                                        data-katedra="@profesor.Katedra"
                                        data-fakultet="@(profesor.FakultetNaziv ?? string.Empty)">@profesor.Naziv</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ProfesorId"></span>
                </div>

                <div class="info-item">
                    <label class="info-label" asp-for="StudentId">Student</label>
                    <select asp-for="StudentId">
                        @foreach (var student in Model.Studenti)
                        {
                            var datumUpisa = student.DatumUpisa.ToString("yyyy-MM-dd");
                            if (Model.StudentId == student.Id)
                            {
                                <option value="@student.Id" selected
                                        data-naziv="@student.Naziv"
                                        data-datum-upisa="@datumUpisa"
                                        data-fakultet="@(student.FakultetNaziv ?? string.Empty)">@student.Naziv</option>
                            }
                            else
                            {
                                <option value="@student.Id"
                                        data-naziv="@student.Naziv"
                                        data-datum-upisa="@datumUpisa"
                                        data-fakultet="@(student.FakultetNaziv ?? string.Empty)">@student.Naziv</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="StudentId"></span>
                </div>

                <div class="info-item">
                    <label class="info-label" asp-for="KolegijId">Kolegij</label>
                    <select asp-for="KolegijId">
                        @foreach (var kolegij in Model.Kolegiji)
                        {
                            if (Model.KolegijId == kolegij.Id)
                            {
                                <option value="@kolegij.Id" selected
                                        data-naziv="@kolegij.Naziv"
                                        data-ects="@kolegij.ECTS"
                                        data-fakultet="@(kolegij.FakultetNaziv ?? string.Empty)">@kolegij.Naziv</option>
                            }
                            else
                            {
                                <option value="@kolegij.Id"
                                        data-naziv="@kolegij.Naziv"
                                        data-ects="@kolegij.ECTS"
                                        data-fakultet="@(kolegij.FakultetNaziv ?? string.Empty)">@kolegij.Naziv</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="KolegijId"></span>
                </div>

                <div class="info-item">
                    <label class="info-label" asp-for="Tip">Tip ocjene</label>
                    <select asp-for="Tip" asp-items="Html.GetEnumSelectList<TipOcjene>()"></select>
                    <span asp-validation-for="Tip"></span>
                </div>

                <div class="info-item">
                    <label class="info-label" asp-for="Vrijednost">Vrijednost (1–5)</label>
                    <input asp-for="Vrijednost" type="number" min="1" max="5" />
                    <span asp-validation-for="Vrijednost"></span>
                </div>

                <div class="info-item">
                    <label class="info-label" asp-for="DatumOcjene">Datum</label>
                    <input asp-for="DatumOcjene" type="date" />
                    <span asp-validation-for="DatumOcjene"></span>
                </div>

                <div class="info-item">
                    <label class="info-label" asp-for="Komentar">Komentar</label>
                    <textarea asp-for="Komentar" rows="3"></textarea>
                    <span asp-validation-for="Komentar"></span>
                </div>
            </div>

            <div class="inline-links inline-links--spaced">
                <button class="link-btn" type="submit">Spremi</button>
                <a class="link-btn link-btn--ghost" asp-action="Index">Odustani</a>
            </div>
        </form>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Napomena</h2>
            <span class="card-tag">Info</span>
        </header>
        <div class="card-copy">
            <p>Trenutni odabir iz padajućih izbornika:</p>
            <div class="info-grid" id="napomenaSummary" aria-live="polite">
                <div class="info-item">
                    <div class="info-label">Profesor</div>
                    <div><strong id="napProfesorNaziv">—</strong></div>
                    <div id="napProfesorMeta"></div>
                </div>
                <div class="info-item">
                    <div class="info-label">Student</div>
                    <div><strong id="napStudentNaziv">—</strong></div>
                    <div id="napStudentMeta"></div>
                </div>
                <div class="info-item">
                    <div class="info-label">Kolegij</div>
                    <div><strong id="napKolegijNaziv">—</strong></div>
                    <div id="napKolegijMeta"></div>
                </div>
                <div class="info-item">
                    <div class="info-label">Tip ocjene</div>
                    <div><strong id="napTip">—</strong></div>
                </div>
            </div>
            <p>Odabrani profesor, student i kolegij moraju postojati u bazi.</p>
            <p>Nakon spremanja, ocjena će se prikazati na listi ocjena.</p>
        </div>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Smjernice</h2>
            <span class="card-tag">Hint</span>
        </header>
        <div class="card-copy">
            <p><strong>Vrijednost</strong> se unosi u rasponu <strong>1–5</strong>.</p>
            <p><strong>Tip ocjene</strong> odaberi prema kontekstu (npr. ispit, projekt, laboratorij).</p>
            <p><strong>Komentar</strong> je opcionalan, ali pomaže pri kasnijem pregledu.</p>
            <p><strong>Datum</strong> koristi datum kada je ocjena dodijeljena.</p>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const professorSelect = document.getElementById('ProfesorId');
            const studentSelect = document.getElementById('StudentId');
            const kolegijSelect = document.getElementById('KolegijId');
            const tipSelect = document.getElementById('Tip');

            const napProfesorNaziv = document.getElementById('napProfesorNaziv');
            const napProfesorMeta = document.getElementById('napProfesorMeta');
            const napStudentNaziv = document.getElementById('napStudentNaziv');
            const napStudentMeta = document.getElementById('napStudentMeta');
            const napKolegijNaziv = document.getElementById('napKolegijNaziv');
            const napKolegijMeta = document.getElementById('napKolegijMeta');
            const napTip = document.getElementById('napTip');

            function selectedOption(selectEl) {
                if (!selectEl || selectEl.selectedIndex < 0) return null;
                return selectEl.options[selectEl.selectedIndex] || null;
            }

            function formatMeta(parts) {
                const filtered = parts.filter(p => !!p && p.trim().length > 0);
                return filtered.length ? filtered.join(' · ') : '';
            }

            function updateNapomena() {
                const professorOpt = selectedOption(professorSelect);
                const studentOpt = selectedOption(studentSelect);
                const kolegijOpt = selectedOption(kolegijSelect);
                const tipOpt = selectedOption(tipSelect);

                if (napProfesorNaziv) {
                    napProfesorNaziv.textContent = professorOpt?.dataset?.naziv || professorOpt?.text || '—';
                }
                if (napProfesorMeta) {
                    const meta = formatMeta([
                        professorOpt?.dataset?.katedra ? `Katedra: ${professorOpt.dataset.katedra}` : '',
                        professorOpt?.dataset?.fakultet ? `Fakultet: ${professorOpt.dataset.fakultet}` : ''
                    ]);
                    napProfesorMeta.textContent = meta;
                }

                if (napStudentNaziv) {
                    napStudentNaziv.textContent = studentOpt?.dataset?.naziv || studentOpt?.text || '—';
                }
                if (napStudentMeta) {
                    const meta = formatMeta([
                        studentOpt?.dataset?.datumUpisa ? `Upis: ${studentOpt.dataset.datumUpisa}` : '',
                        studentOpt?.dataset?.fakultet ? `Fakultet: ${studentOpt.dataset.fakultet}` : ''
                    ]);
                    napStudentMeta.textContent = meta;
                }

                if (napKolegijNaziv) {
                    napKolegijNaziv.textContent = kolegijOpt?.dataset?.naziv || kolegijOpt?.text || '—';
                }
                if (napKolegijMeta) {
                    const ects = kolegijOpt?.dataset?.ects ? `ECTS: ${kolegijOpt.dataset.ects}` : '';
                    const meta = formatMeta([
                        ects,
                        kolegijOpt?.dataset?.fakultet ? `Fakultet: ${kolegijOpt.dataset.fakultet}` : ''
                    ]);
                    napKolegijMeta.textContent = meta;
                }

                if (napTip) {
                    napTip.textContent = tipOpt?.text || '—';
                }
            }

            professorSelect?.addEventListener('change', updateNapomena);
            studentSelect?.addEventListener('change', updateNapomena);
            kolegijSelect?.addEventListener('change', updateNapomena);
            tipSelect?.addEventListener('change', updateNapomena);

            updateNapomena();
        })();
    </script>
}
