@model IEnumerable<Student>
@{
    ViewData["Title"] = "Studenti";
}

<section class="page-head">
    <h1 class="page-title">Studenti</h1>
    <p class="page-subtitle">Pregled svih studenata i brz pristup detaljima.</p>
</section>

<section class="page-actions">
    <a class="link-btn" asp-action="Create">Dodaj studenta</a>
</section>

<section class="list-toolbar"
         data-ajax-list-root
         data-search-url="@Url.Action("Search", "Student")"
         data-target-id="studentListTarget">
    <label class="info-label" for="studentSearch">Brza pretraga</label>
    <input id="studentSearch"
           type="search"
           class="search-input"
           placeholder="Pretrazi po imenu ili prezimenu..."
           data-ajax-search-input />
</section>

<div id="studentListTarget">
    <partial name="_StudentCards" model="Model" />
</div>
