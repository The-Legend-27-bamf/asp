@model IEnumerable<Student>
@{
    ViewData["Title"] = "Studenti";
}

<section class="page-head">
    <h1 class="page-title">Studenti</h1>
    <p class="page-subtitle">Pregled svih studenata i brz pristup detaljima.</p>
</section>

@if (@Model == null || !@Model.Any())
{
    <p class="empty-note">Nema dostupnih studenata.</p>
}
else
{
    <section class="cards-grid">
        @foreach (var student in @Model)
        {
            <article class="entity-card">
                <div class="card-top">
                    <h2 class="card-title">@student.Ime @student.Prezime</h2>
                </div>
                <div class="chip-wrap">
                    <span class="chip chip--accent">Upis @student.DatumUpisa.ToString("dd.MM.yyyy")</span>
                    <span class="chip chip--ok">Ocjene @student.DaneOcjene.Count</span>
                </div>
                <a class="link-btn" asp-action="Details" asp-route-id="@student.Id">Details</a>
            </article>
        }
    </section>
}
