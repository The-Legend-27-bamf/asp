@model Student
@{
    ViewData["Title"] = "Detalji studenta";
}

<section class="detail-hero">
    <span class="hero-badge">Student</span>
    <div class="hero-main">
        <h1 class="hero-title">@Model.Ime @Model.Prezime</h1>
        <p class="hero-subtitle">Detaljni prikaz podataka o studentu.</p>
    </div>
    <div class="hero-pills">
        <span class="hero-pill">Upis <strong>@Model.DatumUpisa.ToString("dd.MM.yyyy")</strong></span>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card core-card">
        <header class="card-header">
            <h2>Osnovni podaci</h2>
            <span class="card-tag">Profil</span>
        </header>
        <div class="info-grid">
            <div class="info-item"><span class="info-label">Ime</span><span class="info-value">@Model.Ime</span></div>
            <div class="info-item"><span class="info-label">Prezime</span><span class="info-value">@Model.Prezime</span></div>
            <div class="info-item"><span class="info-label">Datum upisa</span><span class="info-value">@Model.DatumUpisa.ToString("dd.MM.yyyy")</span></div>
        </div>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Dane ocjene</h2>
            <span class="card-tag">Aktivnost</span>
        </header>
        @if (@Model.DaneOcjene.Count == 0)
        {
            <p class="empty-state">Student nema unesenih ocjena.</p>
        }
        else
        {
            <div class="grade-list">
                @foreach (var ocjena in @Model.DaneOcjene)
                {
                    <a class="grade-item" asp-controller="Ocjena" asp-action="Details" asp-route-id="@ocjena.Id">
                        <div class="grade-pill-center">
                            @{
                                var filledStars = ocjena.Vrijednost;
                                if (filledStars < 0) filledStars = 0;
                                if (filledStars > 5) filledStars = 5;
                            }
                            <span class="chip chip--sun chip--stars" aria-label="Ocjena: @ocjena.Vrijednost od 5">
                                <span class="stars" aria-hidden="true">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <svg class="star @(i <= filledStars ? "is-filled" : "is-empty")" viewBox="0 0 24 24" focusable="false" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M12 2.7l2.9 6.1 6.7.9-4.9 4.7 1.2 6.7L12 17.9 6.1 21.1l1.2-6.7-4.9-4.7 6.7-.9L12 2.7Z" />
                                        </svg>
                                    }
                                </span>
                            </span>
                        </div>
                        <div class="grade-head">
                            <span class="chip chip--accent">Tip @ocjena.Tip</span>
                            <span class="chip chip--ok">@ocjena.DatumOcjene.ToString("dd.MM.yyyy")</span>
                        </div>
                        <div class="grade-rows">
                            <div class="grade-row">
                                <span class="grade-label">Kolegij</span>
                                <span class="grade-value">@ocjena.Kolegij.Naziv</span>
                            </div>
                            <div class="grade-row">
                                <span class="grade-label">Profesor</span>
                                <span class="grade-value">@ocjena.Profesor.Ime @ocjena.Profesor.Prezime</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </article>
</section>

<a class="link-btn link-btn--ghost back-link" asp-action="Index">Povratak na Index</a>
