@model HomeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="detail-hero">
    <span class="hero-badge">Dashboard</span>
    <div class="hero-main">
        <h1 class="hero-title">Nasumicni pregled</h1>
        <p class="hero-subtitle">Nasumicni pregled podataka po jednom objektu svake vrste.</p>
    </div>
</section>

<div class="inline-links page-actions">
    <a class="link-btn" asp-controller="Home" asp-action="Index">Osvjezi nasumicni prikaz</a>
</div>

<section class="home-grid">
    <article class="entity-card">
        <div class="card-top">
            <h2 class="card-title">Student</h2>
        </div>
        @if (@Model.Student is null)
        {
            <p class="empty-note">Nema podataka.</p>
        }
        else
        {
            <div class="card-lines">
                <p class="card-meta">@Model.Student.Ime @Model.Student.Prezime</p>
                <p class="card-meta">Datum upisa: @Model.Student.DatumUpisa.ToString("dd.MM.yyyy")</p>
                <p class="card-meta">Broj danih ocjena: @Model.Student.DaneOcjene.Count</p>
            </div>
            <a class="link-btn" asp-controller="Student" asp-action="Details" asp-route-id="@Model.Student.Id">Details</a>
        }
    </article>

    <article class="entity-card">
        <div class="card-top">
            <h2 class="card-title">Kolegij</h2>
        </div>
        @if (@Model.Kolegij is null)
        {
            <p class="empty-note">Nema podataka.</p>
        }
        else
        {
            <div class="card-lines">
                <p class="card-meta">@Model.Kolegij.Naziv</p>
                <p class="card-meta">ECTS: @Model.Kolegij.ECTS</p>
                <p class="card-meta">Profesori: @Model.Kolegij.Profesori.Count | Studenti: @Model.Kolegij.Studenti.Count</p>
            </div>
            <a class="link-btn" asp-controller="Kolegij" asp-action="Details" asp-route-id="@Model.Kolegij.Id">Details</a>
        }
    </article>

    <article class="entity-card">
        <div class="card-top">
            <h2 class="card-title">Profesor</h2>
        </div>
        @if (@Model.Profesor is null)
        {
            <p class="empty-note">Nema podataka.</p>
        }
        else
        {
            <div class="card-lines">
                <p class="card-meta">@Model.Profesor.Ime @Model.Profesor.Prezime</p>
                <p class="card-meta">Katedra: @Model.Profesor.Katedra</p>
                <p class="card-meta">Ocjene: @Model.Profesor.Ocjene.Count | Kolegiji: @Model.Profesor.Kolegiji.Count</p>
            </div>
            <a class="link-btn" asp-controller="Profesor" asp-action="Details" asp-route-id="@Model.Profesor.Id">Details</a>
        }
    </article>

    <article class="entity-card">
        <div class="card-top">
            <h2 class="card-title">Ocjena</h2>
        </div>
        @if (@Model.Ocjena is null)
        {
            <p class="empty-note">Nema podataka.</p>
        }
        else
        {
            <div class="grade-pill-center">
                @{
                    var filledStars = Model.Ocjena.Vrijednost;
                    if (filledStars < 0) filledStars = 0;
                    if (filledStars > 5) filledStars = 5;
                }
                <span class="chip chip--sun chip--stars" aria-label="Ocjena: @Model.Ocjena.Vrijednost od 5">
                    <span class="stars" aria-hidden="true">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <svg class="star @(i <= filledStars ? "is-filled" : "is-empty")" viewBox="0 0 24 24" focusable="false" xmlns="http://www.w3.org/2000/svg">
                                <path d="M12 2.7l2.9 6.1 6.7.9-4.9 4.7 1.2 6.7L12 17.9 6.1 21.1l1.2-6.7-4.9-4.7 6.7-.9L12 2.7Z" />
                            </svg>
                        }
                    </span>
                </span>
            </div>
            <div class="card-lines">
                <p class="card-meta">Tip: @Model.Ocjena.Tip</p>
                <p class="card-meta">Student: @Model.Ocjena.Student.Ime @Model.Ocjena.Student.Prezime</p>
                <p class="card-meta">Kolegij: @Model.Ocjena.Kolegij.Naziv</p>
            </div>
            <a class="link-btn" asp-controller="Ocjena" asp-action="Details" asp-route-id="@Model.Ocjena.Id">Details</a>
        }
    </article>

    <article class="entity-card">
        <div class="card-top">
            <h2 class="card-title">Fakultet</h2>
        </div>
        @if (@Model.Fakultet is null)
        {
            <p class="empty-note">Nema podataka.</p>
        }
        else
        {
            <div class="card-lines">
                <p class="card-meta">@Model.Fakultet.Naziv</p>
                <p class="card-meta">Profesori: @Model.Fakultet.Profesori.Count</p>
                <p class="card-meta">Studenti: @Model.Fakultet.Studenti.Count | Kolegiji: @Model.Fakultet.Kolegiji.Count</p>
            </div>
            <a class="link-btn" asp-controller="Fakultet" asp-action="Details" asp-route-id="@Model.FakultetId">Details</a>
        }
    </article>

    <article class="entity-card">
        <div class="card-top">
            <h2 class="card-title">Izvjestaj</h2>
        </div>
        @if (@Model.Izvjestaj is null)
        {
            <p class="empty-note">Nema podataka.</p>
        }
        else
        {
            <div class="card-lines">
                <p class="card-meta">Profesor: @Model.Izvjestaj.Profesor.Ime @Model.Izvjestaj.Profesor.Prezime</p>
                <p class="card-meta">Prosjecna ocjena: @Model.Izvjestaj.ProsjecnaOcjena.ToString("0.00")</p>
                <p class="card-meta">Broj ocjena: @Model.Izvjestaj.BrojOcjena</p>
            </div>
            <a class="link-btn" asp-controller="Izvjestaj" asp-action="Details" asp-route-id="@Model.Izvjestaj.Id">Details</a>
        }
    </article>
</section>
