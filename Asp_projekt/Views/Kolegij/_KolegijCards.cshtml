@model IEnumerable<Kolegij>

@if (@Model == null || !@Model.Any())
{
    <p class="empty-note">Nema dostupnih kolegija za odabrani filter.</p>
}
else
{
    <section class="cards-grid" data-ajax-animated-list>
        @foreach (var kolegij in @Model)
        {
            <article class="entity-card">
                <div class="card-top">
                    <h2 class="card-title">@kolegij.Naziv</h2>
                </div>
                <div class="chip-wrap">
                    <span class="chip chip--accent">ECTS @kolegij.ECTS</span>
                    <span class="chip chip--ok">Prof: @kolegij.Profesori.Count</span>
                    <span class="chip chip--ok">Stud: @kolegij.Studenti.Count</span>
                </div>
                <div class="inline-links">
                    <a class="link-btn" asp-action="Details" asp-route-id="@kolegij.Id">Details</a>
                    <a class="link-btn link-btn--ghost" asp-action="Edit" asp-route-id="@kolegij.Id">Uredi</a>
                    <form asp-action="Delete" asp-route-id="@kolegij.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button class="link-btn link-btn--ghost" type="submit" onclick="return confirm('Obrisati ovaj kolegij?');">
                            Obrisi
                        </button>
                    </form>
                </div>
            </article>
        }
    </section>
}
