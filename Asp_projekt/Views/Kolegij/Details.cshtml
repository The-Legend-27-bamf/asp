@model Kolegij
@{
    ViewData["Title"] = "Detalji kolegija";
}

<section class="kolegij-hero">
    <span class="hero-badge">Kolegij</span>
    <div class="hero-main">
        <h1 class="hero-title">@Model.Naziv</h1>
        <p class="hero-subtitle">Detaljni prikaz podataka o kolegiju.</p>
    </div>
    <div class="hero-pills">
        <span class="hero-pill">ECTS <strong>@Model.ECTS</strong></span>
    </div>
</section>

<section class="kolegij-grid">
    <article class="kolegij-card core-card">
        <header class="card-header">
            <h2>Osnovni podaci</h2>
            <span class="card-tag">Glavno</span>
        </header>
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Naziv</span>
                <span class="info-value">@Model.Naziv</span>
            </div>
            <div class="info-item">
                <span class="info-label">ECTS</span>
                <span class="info-value">@Model.ECTS</span>
            </div>
        </div>
    </article>

    <article class="kolegij-card">
        <header class="card-header">
            <h2>Profesori</h2>
            <span class="card-tag">Mentori</span>
        </header>
        @if (@Model.Profesori.Count == 0)
        {
            <p class="empty-state">Nema profesora.</p>
        }
        else
        {
            <div class="chip-list">
                @foreach (var profesor in @Model.Profesori)
                {
                    <a class="name-chip" asp-controller="Profesor" asp-action="Details" asp-route-id="@profesor.Id">@profesor.Ime @profesor.Prezime</a>
                }
            </div>
        }
    </article>

    <article class="kolegij-card">
        <header class="card-header">
            <h2>Studenti</h2>
            <span class="card-tag">Polaznici</span>
        </header>
        @if (@Model.Studenti.Count == 0)
        {
            <p class="empty-state">Nema studenata.</p>
        }
        else
        {
            <div class="chip-list">
                @foreach (var student in @Model.Studenti)
                {
                    <a class="name-chip" asp-controller="Student" asp-action="Details" asp-route-id="@student.Id">@student.Ime @student.Prezime</a>
                }
            </div>
        }
    </article>
</section>
<div class="inline-links inline-links--spaced">
    <a class="link-btn" asp-action="Edit" asp-route-id="@Model.Id">Uredi kolegij</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button class="link-btn link-btn--ghost" type="submit" onclick="return confirm('Obrisati ovaj kolegij?');">
            Obrisi kolegij
        </button>
    </form>
    <a class="link-btn link-btn--ghost" asp-action="Index">Povratak na Index</a>
</div>
