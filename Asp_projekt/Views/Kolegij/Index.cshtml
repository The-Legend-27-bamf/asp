@model IEnumerable<Kolegij>
@{
    ViewData["Title"] = "Kolegiji";
}

<section class="page-head">
    <h1 class="page-title">Kolegiji</h1>
    <p class="page-subtitle">Kartični pregled kolegija, profesora i studenata.</p>
</section>

<section class="page-actions">
    <a class="link-btn" asp-action="Create">Dodaj kolegij</a>
</section>

<section class="list-toolbar"
         data-ajax-list-root
         data-search-url="@Url.Action("Search", "Kolegij")"
         data-target-id="kolegijListTarget">
    <label class="info-label" for="kolegijSearch">Brza pretraga</label>
    <input id="kolegijSearch"
           type="search"
           class="search-input"
           placeholder="Pretrazi po nazivu, profesoru ili studentu..."
           data-ajax-search-input />
</section>

<div id="kolegijListTarget">
    <partial name="_KolegijCards" model="Model" />
</div>
