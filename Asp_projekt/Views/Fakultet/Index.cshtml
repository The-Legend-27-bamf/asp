@model IEnumerable<Fakultet>
@{
    ViewData["Title"] = "Fakulteti";
}

<section class="page-head">
    <h1 class="page-title">Fakulteti</h1>
    <p class="page-subtitle">Pregled fakulteta i povezanih profesora, studenata i kolegija.</p>
</section>

<section class="page-actions">
    <a class="link-btn" asp-action="Create">Dodaj fakultet</a>
</section>

<section class="list-toolbar"
         data-ajax-list-root
         data-search-url="@Url.Action("Search", "Fakultet")"
         data-target-id="fakultetListTarget">
    <label class="info-label" for="fakultetSearch">Brza pretraga</label>
    <input id="fakultetSearch"
           type="search"
           class="search-input"
           placeholder="Pretrazi po nazivu fakulteta..."
           data-ajax-search-input />
</section>

<div id="fakultetListTarget">
    <partial name="_FakultetCards" model="Model" />
</div>
