@model Fakultet
@{
    ViewData["Title"] = "Detalji fakulteta";
}

<section class="detail-hero">
    <span class="hero-badge">Fakultet</span>
    <div class="hero-main">
        <h1 class="hero-title">@Model.Naziv</h1>
        <p class="hero-subtitle">Detaljni prikaz podataka o fakultetu.</p>
    </div>
    <div class="hero-pills">
        <span class="hero-pill">Prof <strong>@Model.Profesori.Count</strong></span>
        <span class="hero-pill">Stud <strong>@Model.Studenti.Count</strong></span>
        <span class="hero-pill">Kol <strong>@Model.Kolegiji.Count</strong></span>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card core-card">
        <header class="card-header">
            <h2>Osnovni podaci</h2>
            <span class="card-tag">Pregled</span>
        </header>
        <div class="info-grid">
            <div class="info-item"><span class="info-label">Naziv</span><span class="info-value">@Model.Naziv</span></div>
            <div class="info-item"><span class="info-label">Broj profesora</span><span class="info-value">@Model.Profesori.Count</span></div>
            <div class="info-item"><span class="info-label">Broj studenata</span><span class="info-value">@Model.Studenti.Count</span></div>
            <div class="info-item"><span class="info-label">Broj kolegija</span><span class="info-value">@Model.Kolegiji.Count</span></div>
        </div>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Profesori</h2>
            <span class="card-tag">Tim</span>
        </header>
        @if (@Model.Profesori.Count == 0)
        {
            <p class="empty-state">Nema profesora.</p>
        }
        else
        {
            <div class="chip-list">
                @foreach (var profesor in @Model.Profesori)
                {
                    <a class="name-chip" asp-controller="Profesor" asp-action="Details" asp-route-id="@profesor.Id">@profesor.Ime @profesor.Prezime</a>
                }
            </div>
        }
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Studenti</h2>
            <span class="card-tag">Polaznici</span>
        </header>
        @if (@Model.Studenti.Count == 0)
        {
            <p class="empty-state">Nema studenata.</p>
        }
        else
        {
            <div class="chip-list">
                @foreach (var student in @Model.Studenti)
                {
                    <a class="name-chip" asp-controller="Student" asp-action="Details" asp-route-id="@student.Id">@student.Ime @student.Prezime</a>
                }
            </div>
        }
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Kolegiji</h2>
            <span class="card-tag">Nastava</span>
        </header>
        @if (@Model.Kolegiji.Count == 0)
        {
            <p class="empty-state">Nema kolegija.</p>
        }
        else
        {
            <div class="chip-list">
                @foreach (var kolegij in @Model.Kolegiji)
                {
                    <a class="name-chip" asp-controller="Kolegij" asp-action="Details" asp-route-id="@kolegij.Id">@kolegij.Naziv</a>
                }
            </div>
        }
    </article>
</section>
<div class="inline-links inline-links--spaced">
    <a class="link-btn" asp-action="Edit" asp-route-id="@Model.Id">Uredi fakultet</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button class="link-btn link-btn--ghost" type="submit" onclick="return confirm('Obrisati ovaj fakultet?');">
            Obrisi fakultet
        </button>
    </form>
    <a class="link-btn link-btn--ghost" asp-action="Index">Povratak na Index</a>
</div>
