@model IEnumerable<Profesor>
@{
    ViewData["Title"] = "Profesori";
}

<section class="page-head">
    <h1 class="page-title">Profesori</h1>
    <p class="page-subtitle">Pregled profesora s katedrama i aktivnostima.</p>
</section>

<section class="page-actions">
    <a class="link-btn" asp-action="Create">Dodaj profesora</a>
</section>

<section class="list-toolbar"
         data-ajax-list-root
         data-search-url="@Url.Action("Search", "Profesor")"
         data-target-id="profesorListTarget">
    <label class="info-label" for="profesorSearch">Brza pretraga</label>
    <input id="profesorSearch"
           type="search"
           class="search-input"
           placeholder="Pretrazi po imenu, prezimenu ili katedri..."
           data-ajax-search-input />
</section>

<div id="profesorListTarget">
    <partial name="_ProfesorCards" model="Model" />
</div>
