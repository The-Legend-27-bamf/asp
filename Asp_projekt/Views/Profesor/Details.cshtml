@model Profesor
@{
    ViewData["Title"] = "Detalji profesora";
}

<section class="detail-hero">
    <span class="hero-badge">Profesor</span>
    <div class="hero-main">
        <h1 class="hero-title">@Model.Ime @Model.Prezime</h1>
        <p class="hero-subtitle">Detaljni prikaz podataka o profesoru.</p>
    </div>
    <div class="hero-pills">
        <span class="hero-pill"><strong>@Model.Katedra</strong></span>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-card core-card">
        <header class="card-header">
            <h2>Osnovni podaci</h2>
            <span class="card-tag">Profil</span>
        </header>
        <div class="info-grid">
            <div class="info-item"><span class="info-label">Ime</span><span class="info-value">@Model.Ime</span></div>
            <div class="info-item"><span class="info-label">Prezime</span><span class="info-value">@Model.Prezime</span></div>
            <div class="info-item"><span class="info-label">Katedra</span><span class="info-value">@Model.Katedra</span></div>
        </div>
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Ocjene</h2>
            <span class="card-tag">Aktivnost</span>
        </header>
        @if (@Model.Ocjene.Count == 0)
        {
            <p class="empty-state">Nema ocjena.</p>
        }
        else
        {
            <div class="grade-list">
                @foreach (var ocjena in @Model.Ocjene)
                {
                    <a class="grade-item" asp-controller="Ocjena" asp-action="Details" asp-route-id="@ocjena.Id">
                        <div class="grade-pill-center">
                            @{
                                var filledStars = ocjena.Vrijednost;
                                if (filledStars < 0) filledStars = 0;
                                if (filledStars > 5) filledStars = 5;
                            }
                            <span class="chip chip--sun chip--stars" aria-label="Ocjena: @ocjena.Vrijednost od 5">
                                <span class="stars" aria-hidden="true">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <svg class="star @(i <= filledStars ? "is-filled" : "is-empty")" viewBox="0 0 24 24" focusable="false" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M12 2.7l2.9 6.1 6.7.9-4.9 4.7 1.2 6.7L12 17.9 6.1 21.1l1.2-6.7-4.9-4.7 6.7-.9L12 2.7Z" />
                                        </svg>
                                    }
                                </span>
                            </span>
                        </div>
                        <div class="grade-head">
                            <span class="chip chip--accent">Tip @ocjena.Tip</span>
                            <span class="chip chip--ok">@ocjena.DatumOcjene.ToString("dd.MM.yyyy")</span>
                        </div>
                        <div class="grade-rows">
                            <div class="grade-row">
                                <span class="grade-label">Student</span>
                                <span class="grade-value">@ocjena.Student.Ime @ocjena.Student.Prezime</span>
                            </div>
                            <div class="grade-row">
                                <span class="grade-label">Kolegij</span>
                                <span class="grade-value">@ocjena.Kolegij.Naziv</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </article>

    <article class="detail-card">
        <header class="card-header">
            <h2>Kolegiji</h2>
            <span class="card-tag">Nastava</span>
        </header>
        @if (@Model.Kolegiji.Count == 0)
        {
            <p class="empty-state">Nema kolegija.</p>
        }
        else
        {
            <div class="chip-list">
                @foreach (var kolegij in @Model.Kolegiji)
                {
                    <a class="name-chip" asp-controller="Kolegij" asp-action="Details" asp-route-id="@kolegij.Id">@kolegij.Naziv</a>
                }
            </div>
        }
    </article>
</section>
<div class="inline-links inline-links--spaced">
    <a class="link-btn" asp-action="Edit" asp-route-id="@Model.Id">Uredi profesora</a>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button class="link-btn link-btn--ghost" type="submit" onclick="return confirm('Obrisati ovog profesora?');">
            Obrisi profesora
        </button>
    </form>
    <a class="link-btn link-btn--ghost" asp-action="Index">Povratak na Index</a>
</div>
